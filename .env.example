# App
APP_NAME=rag-document-processor
ENV=dev
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Database (async URL for app; sync URL for Alembic can be derived)
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
# Alembic (sync driver)
DATABASE_URL_SYNC=postgresql://rag:rag@localhost:5432/rag
# Auto-run Alembic on API startup (when unset: on for ENV=dev|development|test, off otherwise)
DATABASE_AUTO_MIGRATE=true
# Create the Postgres database if it does not exist (when unset: same rule as above). Requires CREATEDB-capable role; disable on managed Postgres.
DATABASE_AUTO_CREATE=true

# Redis (broker/results/cache/revocation/streams — use different DB indexes in prod)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_DB=0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Redis Cloud / many managed hosts only allow logical DB 0. If you see "DB index is out of range",
# point all three URLs at .../0 (Celery key prefixes still keep broker vs results apart). Use
# rediss:// when the provider requires TLS (often the default in their connection string).

# JWT
JWT_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Blob storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
# S3 / MinIO (when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=rag-uploads
S3_REGION=us-east-1

# Ingestion limits
MAX_UPLOAD_BYTES=20971520
MAX_URL_FETCH_BYTES=20971520
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Embedding pipeline
# Embedding pipeline (optional per ingest; see API fields embedding_pipeline, macro_splitter, embedder_provider, *_embedding_model).
EMBEDDING_PIPELINE=chunk_then_embed
MACRO_SPLITTER=recursive
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Default output embedding size when ingest omits `embedding_dimensions` (Matryoshka-capable models only).
# Ranges depend on EMBEDDING_PIPELINE + model (e.g. text-embedding-3-small: 256–1536; jina-embeddings*: 256–1024).
EMBEDDING_DIMENSIONS=
EMBEDDER_CONTEXT_TOKENS=8192

# LlamaIndex is used in-process for readers/splitters (no separate "LlamaIndex API key").
# Semantic macro splitting uses OpenAI embeddings — set OPENAI_API_KEY above.
# LlamaCloud Parse (optional): when LLAMA_CLOUD_API_KEY is set, PDF/DOCX go through
# cloud parse; otherwise extraction uses local llama-index-readers-file.
LLAMA_CLOUD_API_KEY=
# Default LlamaCloud parse tier when ingest omits `llama_parse_tier` (fast | cost_effective | agentic | agentic_plus).
# Override per job: multipart form field on /ingest/file, or JSON field on /ingest/url and /ingest/text.
LLAMA_PARSE_TIER=agentic

# Redis stream sink
REDIS_STREAM_MAXLEN=10000

# Celery
CELERY_TASK_DEFAULT_QUEUE=ingest
