# Reference: values for GitHub Environment secrets (staging)
# Do NOT commit real secrets. Copy names into GitHub → Settings → Environments → staging.
# Full step-by-step guide: docs/DEPLOY_CLOUD_RUN.md

# --- GCP deploy ---
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GCP_SA_KEY={"type":"service_account",...}
CLOUD_SQL_CONNECTION_NAME=project:region:rag-sql

# --- Database (Cloud SQL via Unix socket on Cloud Run) ---
DATABASE_URL=postgresql+asyncpg://rag:PASSWORD@/rag?host=/cloudsql/project:region:rag-sql
DATABASE_URL_SYNC=postgresql://rag:PASSWORD@/rag?host=/cloudsql/project:region:rag-sql

# --- Redis (e.g. Redis Cloud) ---
REDIS_URL=rediss://default:PASSWORD@host:port/0
CELERY_BROKER_URL=rediss://default:PASSWORD@host:port/1
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@host:port/2

# --- App secrets ---
API_KEY_ADMIN_SECRET=change-me-long-random
OPENAI_API_KEY=sk-...
# JINA_API_KEY=
# LLAMA_CLOUD_API_KEY=

# --- GCS via S3-compatible API ---
S3_BUCKET_NAME=your-project-rag-uploads
S3_ACCESS_KEY_ID=GOOG...
S3_SECRET_ACCESS_KEY=...
S3_ENDPOINT_URL=https://storage.googleapis.com
